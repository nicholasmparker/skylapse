# Local development environment variables
# Copy to .env and customize.

# Admin token for protected endpoints
ADMIN_TOKEN=change-me

# Local storage directory for images/videos
# On the Pi we default to /data/timelapse via configs/config.yaml
SKYLAPSE_LOCAL_DIR=./.data

# Prefer mock camera in local dev; on the Pi omit to use Picamera2 if available
SKYLAPSE_CAMERA=mock

# Optional S3 settings
# SKYLAPSE_S3_ENDPOINT=https://s3.example.com
# SKYLAPSE_S3_BUCKET=timelapse
